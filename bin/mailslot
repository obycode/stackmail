#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  TARGET="$(readlink "$SOURCE")"
  if [[ "$TARGET" != /* ]]; then
    SOURCE="$(cd "$(dirname "$SOURCE")" && pwd)/$TARGET"
  else
    SOURCE="$TARGET"
  fi
done

ROOT_DIR="$(cd "$(dirname "$SOURCE")/.." && pwd)"
TSX_BIN="$ROOT_DIR/node_modules/.bin/tsx"

if [[ ! -x "$TSX_BIN" ]]; then
  echo "Missing runtime dependencies. Run: npm install" >&2
  exit 1
fi

exec "$TSX_BIN" "$ROOT_DIR/scripts/mailslot-cli.mjs" "$@"
